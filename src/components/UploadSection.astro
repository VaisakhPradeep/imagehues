---
import Button from "./Button.astro";
import ColorPanel from "./ColorPanel.astro";

const uploadImageFrameClass =
  "upload-image-frame h-[180px] w-[240px] px-2.5 pt-2.5 bg-white rounded-t-2xl";
const uploadImageClass = "block h-full w-full object-cover rounded-t-lg";
const uploadPreviewShadow =
  "0 -6px 4px -8px rgba(0, 0, 0, 0.2), 0 -6px 10px 0 rgba(0, 0, 0, 0.02), 0 -22px 18px 0 rgba(0, 0, 0, 0.02)";
---

<section
  id="upload-dropzone"
  class="upload-section hidden rounded-2xl border border-dashed px-2 lg:block"
  aria-label="Upload an image to extract colours. Drag and drop or use the upload button."
>
  <div
    id="upload-initial"
    class="flex items-stretch gap-6 max-md:flex-col max-md:items-center max-md:gap-4 px-2.5"
  >
    <div class="w-fit shrink-0 pt-4">
      <div
        class={uploadImageFrameClass}
        style={`box-shadow: ${uploadPreviewShadow}`}
      >
        <img
          src="/images/upload_section_image.png"
          alt="Example image with extracted colour swatches"
          width="220"
          height="160"
          class={uploadImageClass}
        />
      </div>
    </div>

    <div
      class="flex min-w-0 flex-1 flex-col pt-4 items-start justify-center gap-4 max-md:items-center max-md:text-center"
    >
      <h2
        class="m-0 font-sans text-xl leading-7 font-medium text-text-primary max-[480px]:text-lg"
      >
        Upload your image to get the colours
      </h2>

      <div>
        <input
          type="file"
          id="image-upload"
          accept="image/*"
          class="sr-only"
          aria-label="Choose an image to upload"
        />
        <label for="image-upload" class="inline-block cursor-pointer">
          <Button class="pointer-events-none">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            Upload
          </Button>
        </label>
      </div>

      <p class="m-0 text-sm text-text-secondary">We do not store your images</p>
    </div>
  </div>

  <div id="upload-result" class="hidden">
    <div
      class="flex items-stretch gap-6 max-md:flex-col max-md:items-center max-md:gap-4 px-2.5"
    >
      <div class="w-fit shrink-0 pt-4">
        <div
          class={uploadImageFrameClass}
          style={`box-shadow: ${uploadPreviewShadow}`}
        >
          <img
            id="upload-preview-img"
            alt="Your uploaded image"
            width="220"
            height="160"
            class={uploadImageClass}
          />
        </div>
      </div>

      <div
        class="flex min-w-0 flex-1 flex-col pt-4 items-start justify-center gap-4 max-md:items-center"
      >
        <ColorPanel
          id="upload-color-panel"
          class="w-full max-md:max-w-[280px] items-start"
        />

        <label
          for="image-upload"
          class="inline-flex cursor-pointer items-center gap-2 font-sans text-sm font-medium text-text-primary transition-opacity duration-150 hover:opacity-80"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          Upload another
        </label>
      </div>
    </div>
  </div>
</section>

<style>
  .upload-section {
    border-color: rgb(23 46 58 / 20%);
    background-image: radial-gradient(
      circle,
      var(--color-border) 1px,
      transparent 1px
    );
    background-size: 14px 14px;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .upload-section--dragover {
    border-color: rgb(23 46 58 / 40%);
    background-color: color-mix(
      in srgb,
      var(--color-text-primary) 4%,
      var(--color-surface)
    );
  }
</style>
