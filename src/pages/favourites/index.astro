---
import BaseLayout from '../../layouts/BaseLayout.astro';

const scripts = ['/js/favourites.js'];
---

<BaseLayout
  title="Your Favourite Color Palettes – Image Hues"
  description="View and manage your saved color palettes from Image Hues. Favourites are stored locally in your browser — no login required."
  canonicalPath="/favourites/"
  scripts={scripts}
>
  <div
    class="image-container mx-auto grid max-w-[1200px] grid-cols-4 gap-6 px-6 pb-[50px] pt-8 max-md:grid-cols-2 max-[480px]:grid-cols-1 max-[480px]:px-4"
  ></div>

  <div
    id="empty-favourites-page"
    class="mx-auto max-w-[1200px] px-6 text-center max-[480px]:px-4"
  >
    <img src="/images/empty.png" alt="No favourites yet" class="mx-auto w-1/4 max-[480px]:w-1/2" />
    <p
      class="message mx-auto -mt-5 w-1/2 text-[1.2rem] font-semibold text-text-primary max-[480px]:w-full"
    >
      Hmm, no favourites yet!<br />
      Click on the heart over any image to add :)
    </p>
    <p class="info mx-auto mt-2.5 w-1/2 text-[0.9rem] font-normal text-text-secondary max-[480px]:w-full">
      Favourites uses your browser local storage so that you don't need to login to the site
    </p>
  </div>
</BaseLayout>
