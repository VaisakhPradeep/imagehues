---
import BaseLayout from "../layouts/BaseLayout.astro";
import Loader from "../components/Loader.astro";
import UploadSection from "../components/UploadSection.astro";

const scripts = ["/js/axios.min.js", "/js/color-thief.min.js", "/js/main.js"];
---

<BaseLayout
  title="Image Hues – Color Palettes from Beautiful Photos"
  description="Discover natural, fresh color palettes extracted from beautiful images. Click any swatch to copy its hex code. A free tool for designers and illustrators."
  canonicalPath="/"
  scripts={scripts}
>
  <div class="mx-auto max-w-[1200px] px-6 max-[480px]:px-4">
    <div class="hero grid grid-cols-2 items-center py-24 gap-8">
      <h1
        class="mb-0 font-sans text-[48px] leading-[56px] font-medium text-text-primary max-md:text-[36px] max-md:leading-[44px] max-[480px]:text-[28px] max-[480px]:leading-[36px]"
      >
        Beautiful colour palettes from curated images
      </h1>
      <UploadSection />
    </div>

    <div
      class="image-container mx-auto grid max-w-none grid-cols-4 gap-6 py-[50px] max-md:grid-cols-2 max-[480px]:grid-cols-1 max-[480px]:px-4"
    >
    </div>

    <Loader />

    <footer slot="after-wrapper" class="hidden">
      <h4 class="text-center text-sm font-normal text-text-secondary">
        Refresh to find new palettes, but do remember <a
          href="https://en.wikipedia.org/wiki/Hick%27s_law"
          target="_blank"
          class="cursor-pointer text-text-secondary underline">Hick's law</a
        >
      </h4>
    </footer>
  </div>
</BaseLayout>
