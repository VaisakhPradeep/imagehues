---
export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  scripts?: string[];
  includeUrlMap?: boolean;
}

const site = 'https://imagehues.com';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

const { title, description, canonicalPath, scripts = [], includeUrlMap = false } = Astro.props;
const canonical = `${site}${canonicalPath}`;
const ogImage = `${site}/images/OG_Image.png`;
const hasGa = gaId && gaId !== 'G-XXXXXXXXXX';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Image Hues',
  url: site,
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Any',
  description,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/images/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/images/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/favicon/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon/android-chrome-512x512.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:wght@100..900&display=swap"
      rel="stylesheet"
    />
    {
      hasGa && (
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      )
    }
    {
      hasGa && (
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      )
    }
    <script is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = 'https://www.clarity.ms/tag/' + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, 'clarity', 'script', 'xajqvd9knb');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="bg-background">
      <nav
        class="fixed top-0 left-0 right-0 z-[200] flex h-[50px] items-center justify-between border-b border-border bg-surface px-6 max-[480px]:px-4"
      >
        <a id="logo" href="/" class="flex cursor-pointer items-center no-underline">
          <img
            src="/images/imagehues_logo.svg"
            alt="Image Hues"
            class="h-[25px] w-auto max-[480px]:h-[20px]"
          />
        </a>
        <ul id="nav-items" class="flex shrink-0 list-none items-center">
          <li>
            <a
              href="/"
              class="home text-nav mx-4 font-medium text-text-secondary no-underline transition-colors duration-100 hover:opacity-80 max-[480px]:mx-2 [&.active]:text-text-primary"
              >Home</a
            >
          </li>
          <li>
            <a
              href="/favourites/"
              class="favourites text-nav mx-4 font-medium text-text-secondary no-underline transition-colors duration-100 hover:opacity-80 max-[480px]:mx-2 [&.active]:text-text-primary"
              >Favourites</a
            >
          </li>
          <li>
            <a
              href="/about/"
              class="about text-nav mx-4 font-medium text-text-secondary no-underline transition-colors duration-100 hover:opacity-80 max-[480px]:mx-2 [&.active]:text-text-primary"
              >About</a
            >
          </li>
        </ul>
      </nav>
      <main class="pt-[50px]">
        <slot />
      </main>
    </div>
    <slot name="after-wrapper" />
    {includeUrlMap && <script is:inline src="/js/url-map.js"></script>}
    {includeUrlMap && <script is:inline src="/js/migrate.js"></script>}
    <script is:inline src="/js/color-panel.js"></script>
    <script is:inline src="/js/common.js"></script>
    {scripts.map((script) => <script is:inline src={script}></script>)}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
